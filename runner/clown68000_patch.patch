+/* Log unique JMP/JSR/BSR targets for native coverage auditing.
+ * When running the interpreter, this captures every function entry
+ * point so we know what native needs to compile. */
+#ifndef CLOWN68000_COVERAGE_LOG_DISABLE
+#define COVERAGE_MAX 8192
+static cc_u32f s_coverage_addrs[COVERAGE_MAX];
+static int     s_coverage_count = 0;
+
+static void coverage_log(cc_u32f addr)
+{
+	int i;
+	for (i = 0; i < s_coverage_count; i++)
+		if (s_coverage_addrs[i] == addr) return;
+	if (s_coverage_count < COVERAGE_MAX)
+		s_coverage_addrs[s_coverage_count++] = addr;
+}
+
+int clown68000_coverage_count(void) { return s_coverage_count; }
+cc_u32f clown68000_coverage_addr(int i) {
+	return (i >= 0 && i < s_coverage_count) ? s_coverage_addrs[i] : 0;
+}
+void clown68000_coverage_dump(const char *path)
+{
+	FILE *f = fopen(path, "w");
+	int i;
+	if (!f) return;
+	for (i = 0; i < s_coverage_count; i++)
+		fprintf(f, "extra_func 0x%06X\n", (unsigned)s_coverage_addrs[i]);
+	fclose(f);
+}
+#else
+#define coverage_log(addr) ((void)0)
+#endif
